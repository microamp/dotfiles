set hintchars=asdfghjklerut

noremap j 4j
noremap k 4k
noremap <C-e> 4<C-e>
noremap <C-y> 4<C-y>

map t :tabnew <CR> <F6>
map J :tabnext <CR>
map K :tabprevious <CR>
map x :q <CR>

noremap <C-n> 4j
noremap <C-p> 4k
noremap <C-v> <C-d>
noremap <A-v> <C-u>
noremap <C-f> :tabnext <CR>
noremap <C-b> :tabprevious <CR>
noremap <A-<> gg
noremap <A->> G
